# Backend Environment Configuration Template
# Copy this to .env and fill with your values

# Server Configuration
NODE_ENV=development
PORT=5000
HOST=0.0.0.0

# Database
DATABASE_URL=./data/eofweb.db
DATABASE_BACKUP_PATH=./data/backups

# JWT & Security
JWT_SECRET=your_very_secure_jwt_secret_minimum_32_chars
JWT_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d
BCRYPT_ROUNDS=10

# CORS
CORS_ORIGIN=http://localhost:3000,https://yourdomain.com
CORS_CREDENTIALS=true

# API Keys
STRIPE_SECRET_KEY=sk_test_your_stripe_key
STRIPE_PUBLIC_KEY=pk_test_your_stripe_key

# Email Service
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=noreply@eofweb.com

# Admin Configuration
ADMIN_EMAIL=admin@eofweb.com
ADMIN_PASSWORD=SecureAdminPassword123!

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# Rate Limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100

# Features
ENABLE_KYC=true
ENABLE_2FA=false
ENABLE_EMAIL_VERIFICATION=true

# External APIs
FOREX_API_KEY=your_forex_api_key
MARKET_DATA_API_KEY=your_market_data_key
